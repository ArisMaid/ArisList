APP_ADMIN_PASSWORD=replace-with-a-strong-password
SESSION_SECRET=replace-with-at-least-32-random-characters
APP_PORT=8787
ARISLIST_IMAGE=ghcr.io/arismaid/arislist:latest
DATABASE_URL=sqlite:///app/data/library.sqlite
APP_BIND=0.0.0.0:8787
COMICS_DIR=/library/comics
NOVELS_DIR=/library/novels
AUDIO_DIR=/library/audio
GALLERY_DIR=/library/gallery
COSER_PICTURE_DIR=/library/coser-picture
GENERATED_DIR=/app/generated
CLOUD_CACHE_MAX_BYTES=68719476736
THUMBNAIL_CACHE_MAX_BYTES_PER_DIR=8589934592
COVER_CACHE_DIR=/app/cover-cache
# Leave these unset to use subdirectories below COVER_CACHE_DIR.
# COMIC_COVER_CACHE_DIR=/app/cover-cache/comic
# NOVEL_COVER_CACHE_DIR=/app/cover-cache/novel
# AUDIO_COVER_CACHE_DIR=/app/cover-cache/audio
# GALLERY_COVER_CACHE_DIR=/app/cover-cache/gallery
# COSER_PICTURE_COVER_CACHE_DIR=/app/cover-cache/coser-picture
LIGHTNOVEL_API_BASES=https://api.lightnovel.life,https://cf-api.lightnovel.life
LIGHTNOVEL_ACCESS_TOKEN=
ENRICHMENT_CONCURRENCY=1
ENABLE_FILE_WATCHER=true
WATCH_DEBOUNCE_SECONDS=20
EHTT_URL=https://fastly.jsdelivr.net/gh/EhTagTranslation/DatabaseReleases/db.html.json
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2
QMEDIASYNC_BASE_URL=
QMEDIASYNC_STRM_DIR=./qms-strm
